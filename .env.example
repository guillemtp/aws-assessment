# Source of truth for local and CI variables.
# Copy this file to .env and fill values.

# AWS auth (use profile OR keys)
AWS_PROFILE=personal-admin
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Terraform input variables
PROJECT_NAME=aws-assessment
CANDIDATE_EMAIL=your_email@example.com
GITHUB_USER=your-github-user
TEST_USER_PASSWORD=ReplaceWithAStrongPassword123!
SNS_PUBLISH_ENABLED=false

# Optional overrides for tooling
BACKEND_CONFIG=backend.hcl
